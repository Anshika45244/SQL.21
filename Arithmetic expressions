Column aliases
SELECT COUNTRY,POP/AREA
FROM COUNTRIES
WHERE POP/AREA>2000
ORDER BY POP/AREA DESC

SELECT COUNTRY,
POP/AREA AS DENSITY 
FROM COUNTRIES
WHERE DENSITY>2000
ORDER BY POP /AREA DESC
