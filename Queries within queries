single value subqueries

SELECT AVG(POP)
FROM COUNTRIES

SELECT COUNTRY ,POP
FROM COUNTRIES
WHERE POP>30150531

SELECT COUNTRY ,POP
FROM COUNTRIES
WHERE POP>(SELECT AVG (POP) FROM COUNTRIES)
 single-value queries can be used in comparisons
