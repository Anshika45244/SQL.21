MULTI VALUED SUBQUERIES 

SELECT DISTINCT JOB 
FROM PERSONS
WHERE GENDER= 'FEMALE'

SELECT JOB , TITLE 
FROM JIBS 
WHERE NOT JOB IN 
('W','R','S','M')

SELECT JOB , TITLE
FROM NOT JOB IN 
(SELECT DISTINCT JOB
FROM PERSONS 
WHERE GENDER ='FFEMALE')
MULTI VALUE SUBQUERIES FOLLOW THE IN PERATOR
CORRELATED SUBQUERIES
SELECT JOB ='S'
AND BDATE=
(SELECT MIN (BDATE)
FROM PERSONS
WHERE JOB ='S')

SELECT JOB, NAME
FROM PERSONS AS P
WHERE BDATE = 
(SELECT MIN(BDATE)
FROM  PERSONS
WHERE JOB = P.JOB)

Correlated subqueries are executed multipletimes 
correlated subqueries require table aliases







